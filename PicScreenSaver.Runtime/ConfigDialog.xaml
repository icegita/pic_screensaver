<Window x:Class="PicScreenSaver.Runtime.ConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PicScreenSaver 设置"
        Width="520" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1F1F23">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="PicScreenSaver" FontSize="20" FontWeight="SemiBold"
                   Foreground="#E8E8F0" FontFamily="Segoe UI"/>
        <TextBlock Grid.Row="2" x:Name="InfoText" FontSize="12" Foreground="#9898A8"
                   FontFamily="Segoe UI" TextWrapping="Wrap"/>
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Border Background="#282C36" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="播放时长" FontSize="13" FontWeight="Medium" Foreground="#E8E8F0" FontFamily="Segoe UI"/>
                        <TextBlock Text="图片静止展示的时间" FontSize="11" Foreground="#606070" FontFamily="Segoe UI" Margin="0,2,0,8"/>
                        <DockPanel>
                            <TextBlock x:Name="DisplayDurationLabel" Text="5.0 秒" FontSize="13" Foreground="#6B8CFF"
                                       FontFamily="Consolas" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <Slider x:Name="DisplayDurationSlider" Minimum="1" Maximum="30" Value="5" SmallChange="0.5" LargeChange="1"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="DisplayDuration_ValueChanged"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
                <Border Background="#282C36" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="过渡动画时长" FontSize="13" FontWeight="Medium" Foreground="#E8E8F0" FontFamily="Segoe UI"/>
                        <TextBlock Text="切换动画播放时间" FontSize="11" Foreground="#606070" FontFamily="Segoe UI" Margin="0,2,0,8"/>
                        <DockPanel>
                            <TextBlock x:Name="TransitionDurationLabel" Text="1.2 秒" FontSize="13" Foreground="#6B8CFF"
                                       FontFamily="Consolas" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <Slider x:Name="TransitionDurationSlider" Minimum="0.3" Maximum="5" Value="1.2" SmallChange="0.1" LargeChange="0.5"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="TransitionDuration_ValueChanged"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
                <Border Background="#282C36" CornerRadius="8" Padding="16">
                    <DockPanel>
                        <TextBlock Text="播放顺序" FontSize="13" FontWeight="Medium" Foreground="#E8E8F0" FontFamily="Segoe UI"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <RadioButton x:Name="OrderRandom" Content="随机" IsChecked="True" GroupName="Order"
                                         Foreground="#9898A8" FontSize="12" FontFamily="Segoe UI" Margin="0,0,12,0" Cursor="Hand"/>
                            <RadioButton x:Name="OrderSequential" Content="顺序" GroupName="Order"
                                         Foreground="#9898A8" FontSize="12" FontFamily="Segoe UI" Cursor="Hand"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </StackPanel>
            <Border Grid.Column="2" Background="#282C36" CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="过渡效果" FontSize="13" FontWeight="Medium" Foreground="#E8E8F0"
                               FontFamily="Segoe UI" Margin="0,0,0,8"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="EffectsList"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="InstallButton" Content="安装到系统" Width="100" Height="30"
                    Click="InstallButton_Click" Background="#3ECF8E" Foreground="White"
                    BorderThickness="0" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                    Cursor="Hand"/>
            <Button Content="确定" Width="80" Height="30" HorizontalAlignment="Right"
                    Click="OkButton_Click" Background="#6B8CFF" Foreground="White"
                    BorderThickness="0" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
