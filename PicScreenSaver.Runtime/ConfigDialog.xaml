<Window x:Class="PicScreenSaver.Runtime.ConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PicScreenSaver"
        Width="640" Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True">
    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderThickness="0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"/>
                            <Trigger Property="IsPressed" Value="True"/>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedButtonSmall" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EffectCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#1A1D2A"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Noto Sans SC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBorder" Grid.Column="0" Width="16" Height="16" CornerRadius="4"
                                    BorderBrush="#B0B4C2" BorderThickness="1.5" Margin="16,0,10,0"
                                    VerticalAlignment="Center" Background="Transparent">
                                <TextBlock x:Name="checkMark" Text="&#x2713;" FontSize="9" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Margin="0,3,16,3"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBorder" Property="Background" Value="#5570E8"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="#5570E8"/>
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="#5570E8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="#5570E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedBtn" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border x:Name="ShadowHost" CornerRadius="10" Margin="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Color="#000000" Opacity="0.16"/>
        </Border.Effect>
        <Border x:Name="RootBorder" Background="#F0F1F5" CornerRadius="10" ClipToBounds="True" Loaded="RootBorder_Loaded">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border x:Name="TitleBarBg" Grid.Row="0" Background="#FFFFFF" BorderBrush="#CDD0DA" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <TextBlock x:Name="TitleText" Text="PicScreenSaver" FontSize="12.5" FontWeight="Medium"
                           Foreground="#555A70" FontFamily="Noto Sans SC"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="ThemeToggleBtn" Width="36" Height="44"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="ThemeToggleBtn_Click"
                            MouseEnter="ThemeBtn_MouseEnter" MouseLeave="ThemeBtn_MouseLeave"
                            ToolTip="&#x5207;&#x6362;&#x4E3B;&#x9898;"/>
                    <Button x:Name="CloseBtn" Width="36" Height="44"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="CloseBtn_Click"
                            MouseEnter="CloseBtn_MouseEnter"
                            MouseLeave="CloseBtn_MouseLeave">
                        <Viewbox Width="10" Height="10" Stretch="Uniform">
                            <Grid>
                                <Line x:Name="CloseLine1" X1="0" Y1="0" X2="10" Y2="10"
                                      Stroke="#555A70" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line x:Name="CloseLine2" X1="10" Y1="0" X2="0" Y2="10"
                                      Stroke="#555A70" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 内容 -->
        <Grid Grid.Row="1" Margin="24,16,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左栏 -->
            <Border x:Name="LeftCard" Grid.Column="0" Background="#FFFFFF" BorderBrush="#CDD0DA" BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#CDD0DA" BorderThickness="0,0,0,1" Padding="16,14">
                        <TextBlock Text="&#x64AD;&#x653E;&#x8BBE;&#x7F6E;" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#8A90A6" FontFamily="Noto Sans SC" MinHeight="22"/>
                    </Border>

                    <Border Grid.Row="1" BorderBrush="#CDD0DA" BorderThickness="0,0,0,1" Padding="16,10">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="&#x6BCF;&#x5F20;&#x5C55;&#x793A;&#x65F6;&#x957F;" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#1A1D2A" FontFamily="Noto Sans SC"/>
                                    <TextBlock Text="&#x56FE;&#x7247;&#x9759;&#x6B62;&#x5C55;&#x793A;&#x7684;&#x65F6;&#x95F4;" FontSize="10.5"
                                               Foreground="#8A90A6" FontFamily="Noto Sans SC" Margin="0,1,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="#E8E9EF" CornerRadius="4" BorderThickness="0" Padding="6,2" Margin="0,0,6,0">
                                        <TextBlock x:Name="DisplayDurationLabel" Text="10.0" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#5570E8" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Text="&#x79D2;" FontSize="10.5" Foreground="#555A70" VerticalAlignment="Center" FontFamily="Noto Sans SC"/>
                                </StackPanel>
                            </Grid>
                            <Slider x:Name="DisplayDurationSlider" Minimum="1" Maximum="60" Value="10"
                                    SmallChange="0.5" LargeChange="1" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    ValueChanged="DisplayDuration_ValueChanged"
                                    Foreground="#5570E8" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" BorderBrush="#CDD0DA" BorderThickness="0,0,0,1" Padding="16,10">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="&#x8FC7;&#x6E21;&#x52A8;&#x753B;&#x65F6;&#x957F;" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#1A1D2A" FontFamily="Noto Sans SC"/>
                                    <TextBlock Text="&#x5207;&#x6362;&#x52A8;&#x753B;&#x64AD;&#x653E;&#x7684;&#x65F6;&#x95F4;" FontSize="10.5"
                                               Foreground="#8A90A6" FontFamily="Noto Sans SC" Margin="0,1,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="#E8E9EF" CornerRadius="4" BorderThickness="0" Padding="6,2" Margin="0,0,6,0">
                                        <TextBlock x:Name="TransitionDurationLabel" Text="1.2" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#5570E8" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Text="&#x79D2;" FontSize="10.5" Foreground="#555A70" VerticalAlignment="Center" FontFamily="Noto Sans SC"/>
                                </StackPanel>
                            </Grid>
                            <Slider x:Name="TransitionDurationSlider" Minimum="0.3" Maximum="5" Value="1.2"
                                    SmallChange="0.1" LargeChange="0.5" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    ValueChanged="TransitionDuration_ValueChanged"
                                    Foreground="#5570E8" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#x64AD;&#x653E;&#x987A;&#x5E8F;" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#1A1D2A" FontFamily="Noto Sans SC" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <RadioButton x:Name="OrderSequential" Content="&#x987A;&#x5E8F;" GroupName="Order"
                                             Foreground="#555A70" FontSize="12" FontFamily="Noto Sans SC" Margin="0,0,12,0" Cursor="Hand"/>
                                <RadioButton x:Name="OrderRandom" Content="&#x968F;&#x673A;" IsChecked="True" GroupName="Order"
                                             Foreground="#555A70" FontSize="12" FontFamily="Noto Sans SC" Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="EffectPreviewArea" Grid.Row="4" BorderBrush="#CDD0DA" BorderThickness="0,1,0,0" Background="Transparent"
                            VerticalAlignment="Stretch">
                        <Border x:Name="EffectPreviewBorder" CornerRadius="6" Background="#E8E9EF"
                                Width="220" Height="160" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid>
                                <Image x:Name="EffectPreviewImageA" Stretch="UniformToFill" Opacity="1"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <Image x:Name="EffectPreviewImageB" Stretch="UniformToFill" Opacity="0"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Grid>
                        </Border>
                    </Border>

                    <Border x:Name="EffectInfoBorder" Grid.Row="5" BorderBrush="#CDD0DA" BorderThickness="0,1,0,0" Padding="16,9" Background="#F5F6FA"
                            CornerRadius="0,0,10,10">
                        <DockPanel>
                            <StackPanel>
                                <TextBlock x:Name="SelectedEffectName" Text="Fade" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#1A1D2A" FontFamily="Noto Sans SC"/>
                                <TextBlock x:Name="SelectedEffectDesc" Text="旧图渐隐，新图渐现——最经典的过渡效果" FontSize="11"
                                           Foreground="#555A70" FontFamily="Noto Sans SC" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock x:Name="SelectedEffectCount" Text="0" FontSize="22" FontWeight="SemiBold"
                                           Foreground="#5570E8" FontFamily="Consolas" HorizontalAlignment="Center"/>
                                <TextBlock Text="&#x5DF2;&#x9009;" FontSize="10.5" Foreground="#8A90A6"
                                           FontFamily="Noto Sans SC" Margin="0,1,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 右栏 -->
            <Border x:Name="RightCard" Grid.Column="2" Background="#FFFFFF" BorderBrush="#CDD0DA" BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#CDD0DA" BorderThickness="0,0,0,1" Padding="12,0" Height="46">
                        <Grid VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x5DF2;&#x9009;: " FontSize="11" FontWeight="SemiBold"
                                           Foreground="#8A90A6" FontFamily="Noto Sans SC"/>
                                <TextBlock x:Name="SelectedEffectCountLabel" Text="0" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#5570E8" FontFamily="Noto Sans SC"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button x:Name="SelectAllBtn" Content="&#x5168;&#x9009;" Click="SelectAll_Click"
                                        Background="#E8E9EF" Foreground="#8A90A6" BorderBrush="#CDD0DA"
                                        BorderThickness="1" Padding="7,2" FontSize="10.5" FontFamily="Noto Sans SC"
                                        Cursor="Hand" Style="{StaticResource RoundedButtonSmall}"/>
                                <Button x:Name="ClearAllBtn" Content="&#x6E05;&#x7A7A;" Click="ClearAll_Click"
                                        Background="#E8E9EF" Foreground="#8A90A6" BorderBrush="#CDD0DA"
                                        BorderThickness="1" Padding="7,2" FontSize="10.5" FontFamily="Noto Sans SC"
                                        Margin="6,0,0,0" Cursor="Hand" Style="{StaticResource RoundedButtonSmall}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="Transparent" Padding="8,4">
                        <UniformGrid x:Name="EffectsList" Columns="2" HorizontalAlignment="Center" MaxWidth="400"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部栏 -->
        <Border x:Name="BottomBarBg" Grid.Row="2" Background="#FFFFFF" BorderBrush="#CDD0DA" BorderThickness="0,1,0,0" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="InfoText" Text="" FontSize="11" Foreground="#8A90A6"
                           FontFamily="Noto Sans SC" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="InstallBtn" Content="&#x5B89;&#x88C5;&#x5230;&#x7CFB;&#x7EDF;"
                            Click="InstallButton_Click" Background="#2AAF6A" Foreground="White"
                            BorderThickness="0" FontFamily="Noto Sans SC" FontSize="11" FontWeight="SemiBold"
                            Padding="14,0" Height="28" Cursor="Hand" Visibility="Collapsed"
                            Style="{StaticResource RoundedBtn}"/>
                    <Button Content="&#x786E;&#x5B9A;"
                            Click="OkButton_Click" Background="#5570E8" Foreground="White"
                            BorderThickness="0" FontFamily="Noto Sans SC" FontSize="11" FontWeight="SemiBold"
                            Padding="14,0" Height="28" Cursor="Hand" Margin="6,0,0,0"
                            Style="{StaticResource RoundedBtn}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
        </Border>
    </Border>
</Window>
