<Window x:Class="PicScreenSaver.Runtime.ScreensaverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PicScreenSaver"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Black"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="None"
        Loaded="Window_Loaded"
        MouseMove="Window_MouseMove"
        MouseDown="Window_MouseDown"
        MouseWheel="Window_MouseWheel"
        KeyDown="Window_KeyDown">
    <Grid>
        <Image x:Name="OutgoingImage" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" />
        <Image x:Name="IncomingImage" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" />
    </Grid>
</Window>
