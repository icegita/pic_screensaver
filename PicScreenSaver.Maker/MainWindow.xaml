<Window x:Class="PicScreenSaver.Maker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PicScreenSaver" Width="900" Height="730"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Closing="Window_Closing"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
        StateChanged="Window_StateChanged">
    <Window.Resources>
        <Style x:Key="TabRadioStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Text2Brush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="Tabs"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                VerticalAlignment="Stretch">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EffectCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBorder" Grid.Column="0" Width="16" Height="16" CornerRadius="4"
                                    BorderBrush="{DynamicResource Border2Brush}" BorderThickness="1.5" Margin="16,0,10,0"
                                    VerticalAlignment="Center" Background="Transparent">
                                <TextBlock x:Name="checkMark" Text="&#x2713;" FontSize="9" Foreground="{DynamicResource WhiteBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Margin="0,7,16,7"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToggleRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource Text2Brush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBorder" Grid.Column="0" Width="16" Height="16" CornerRadius="8"
                                    BorderBrush="{DynamicResource Border2Brush}" BorderThickness="1.5" Margin="0,0,10,0"
                                    VerticalAlignment="Center" Background="Transparent">
                                <Border x:Name="checkDot" Width="8" Height="8" CornerRadius="4"
                                        Background="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="checkDot" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedButtonSmall" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>
        <Canvas x:Name="DragOverlay" Panel.ZIndex="9999" IsHitTestVisible="False" Visibility="Collapsed"/>

        <Border x:Name="TitleBarBg" Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="PicScreenSaver" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="12.5" FontWeight="Medium" Foreground="{DynamicResource Text2Brush}" FontFamily="Segoe UI"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="ThemeToggleBtn" Content="&#xE771;" Width="36" Height="44"
                            Background="Transparent" Foreground="{DynamicResource Text2Brush}" BorderThickness="0"
                            FontFamily="Segoe MDL2 Assets" FontSize="12" Cursor="Hand"
                            Click="ThemeToggleBtn_Click"
                            MouseEnter="WindowBtn_MouseEnter" MouseLeave="WindowBtn_MouseLeave"
                            ToolTip="&#x5207;&#x6362;&#x4E3B;&#x9898;"/>
                    <Button x:Name="MinimizeBtn" Content="&#xE921;" Width="36" Height="44"
                            Background="Transparent" Foreground="{DynamicResource Text2Brush}" BorderThickness="0"
                            FontFamily="Segoe MDL2 Assets" FontSize="10" Cursor="Hand"
                            Click="MinimizeBtn_Click"
                            MouseEnter="WindowBtn_MouseEnter" MouseLeave="WindowBtn_MouseLeave"/>
                    <Button x:Name="MaximizeBtn" Content="&#xE922;" Width="36" Height="44"
                            Background="Transparent" Foreground="{DynamicResource Text2Brush}" BorderThickness="0"
                            FontFamily="Segoe MDL2 Assets" FontSize="10" Cursor="Hand"
                            Click="MaximizeBtn_Click"
                            MouseEnter="WindowBtn_MouseEnter" MouseLeave="WindowBtn_MouseLeave"/>
                    <Button x:Name="CloseBtn" Content="&#xE8BB;" Width="36" Height="44"
                            Background="Transparent" Foreground="{DynamicResource Text2Brush}" BorderThickness="0"
                            FontFamily="Segoe MDL2 Assets" FontSize="10" Cursor="Hand"
                            Click="CloseBtn_Click"
                            MouseEnter="CloseBtn_MouseEnter" MouseLeave="CloseBtn_MouseLeave"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="TabBarBg" Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <RadioButton x:Name="TabImages" Content="&#x56FE;&#x7247;&#x5BFC;&#x5165;" IsChecked="True"
                                 Click="TabImages_Click" Style="{StaticResource TabRadioStyle}"/>
                    <RadioButton x:Name="TabEffects" Content="&#x6548;&#x679C;"
                                 Click="TabEffects_Click" Style="{StaticResource TabRadioStyle}"/>
                    <RadioButton x:Name="TabSettings" Content="&#x8BBE;&#x7F6E;"
                                 Click="TabSettings_Click" Style="{StaticResource TabRadioStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button x:Name="GenerateBtn" Content="&#x751F;&#x6210; .scr"
                            Click="GenerateBtn_Click"
                            Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource WhiteBrush}" BorderThickness="0"
                            Style="{StaticResource RoundedButtonStyle}"
                            FontSize="12.5" FontWeight="SemiBold" FontFamily="Segoe UI"
                            Padding="18,0" Height="30" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid x:Name="ImagesPanel" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                    <DockPanel>
                        <Button Content="&#x6DFB;&#x52A0;&#x56FE;&#x7247;" Click="AddImages_Click"
                                DockPanel.Dock="Left"
                                Background="{DynamicResource Surface2Brush}" Foreground="{DynamicResource Text2Brush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Padding="12,0" Height="30" FontSize="12" Style="{StaticResource RoundedButtonStyle}"
                                FontFamily="Segoe UI" Cursor="Hand"/>
                        <Separator Width="1" DockPanel.Dock="Left" Background="{DynamicResource BorderBrush}" Margin="8,4"/>
                        <Button Content="&#x524D;&#x79FB;" Click="MoveUp_Click"
                                DockPanel.Dock="Left"
                                Background="{DynamicResource Surface2Brush}" Foreground="{DynamicResource Text2Brush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Padding="12,0" Height="30" FontSize="12" Style="{StaticResource RoundedButtonStyle}"
                                FontFamily="Segoe UI" Cursor="Hand"/>
                        <Button Content="&#x540E;&#x79FB;" Click="MoveDown_Click"
                                DockPanel.Dock="Left"
                                Background="{DynamicResource Surface2Brush}" Foreground="{DynamicResource Text2Brush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Padding="12,0" Height="30" FontSize="12" Style="{StaticResource RoundedButtonStyle}"
                                FontFamily="Segoe UI" Cursor="Hand"/>
                        <Separator Width="1" DockPanel.Dock="Left" Background="{DynamicResource BorderBrush}" Margin="8,4"/>
                        <Button Content="&#x5168;&#x90E8;&#x79FB;&#x9664;" Click="RemoveAllImages_Click"
                                DockPanel.Dock="Left"
                                Background="{DynamicResource Surface2Brush}" Foreground="{DynamicResource DangerBrush}" BorderBrush="{DynamicResource DangerBgBrush}"
                                BorderThickness="1" Padding="12,0" Height="30" FontSize="12" Style="{StaticResource RoundedButtonStyle}"
                                FontFamily="Segoe UI" Cursor="Hand"/>
                        <TextBlock x:Name="ImageCountText" VerticalAlignment="Center"
                                   Margin="12,0,0,0" FontSize="12"
                                   Foreground="{DynamicResource Text3Brush}" FontFamily="Consolas"
                                   HorizontalAlignment="Right"/>
                    </DockPanel>
                </Border>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="20" Background="{DynamicResource BgBrush}">
                        <WrapPanel x:Name="ImageGrid" ItemWidth="195" ItemHeight="150"/>
                    </ScrollViewer>
                    <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="240"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                <TextBlock Text="&#x9884;&#x89C8;" Padding="16,14,16,10"
                                           FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Text3Brush}" FontFamily="Segoe UI"/>
                            </Border>
                            <Border Grid.Row="1" Background="{DynamicResource Surface2Brush}" ClipToBounds="True">
                                <Image x:Name="PreviewImage" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel Grid.Row="2" Margin="16,14">
                                <TextBlock Text="&#x6587;&#x4EF6;&#x540D;" FontSize="11.5" Foreground="{DynamicResource Text3Brush}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="PreviewFileName" FontSize="11.5" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas" Margin="0,2,0,8"/>
                                <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="&#x539F;&#x59CB;&#x5C3A;&#x5BF8;" FontSize="11.5" Foreground="{DynamicResource Text3Brush}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="PreviewResolution" FontSize="11.5" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas" Margin="0,2,0,8"/>
                                <TextBlock Text="&#x539F;&#x59CB;&#x5927;&#x5C0F;" FontSize="11.5" Foreground="{DynamicResource Text3Brush}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="PreviewOriginalSize" FontSize="11.5" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas" Margin="0,2,0,8"/>
                                <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="&#x538B;&#x7F29;&#x540E;" FontSize="11.5" Foreground="{DynamicResource Text3Brush}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="PreviewCompressedSize" FontSize="11.5" Foreground="{DynamicResource SuccessBrush}" FontFamily="Consolas" Margin="0,2,0,4"/>
                                <TextBlock Text="&#x538B;&#x7F29;&#x7387;" FontSize="11.5" Foreground="{DynamicResource Text3Brush}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="PreviewCompressionRatio" FontSize="11.5" Foreground="{DynamicResource SuccessBrush}" FontFamily="Consolas" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Row="3" Margin="16,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="&#x64AD;&#x653E;&#x987A;&#x5E8F;" FontSize="11" Foreground="{DynamicResource Text3Brush}" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="OrderSequential" Content="&#x987A;&#x5E8F;" GroupName="PlayOrder" Margin="0,0,12,0" Style="{StaticResource ToggleRadioStyle}"/>
                                        <RadioButton x:Name="OrderRandom" Content="&#x968F;&#x673A;" IsChecked="True" GroupName="PlayOrder" Style="{StaticResource ToggleRadioStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="EffectsPanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="16,14,16,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <TextBlock Text="&#x9009;&#x62E9;&#x6548;&#x679C;" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text3Brush}" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="&#x5168;&#x9009;" Click="SelectAllEffects_Click"
                                            Background="{DynamicResource Surface2Brush}" Foreground="{DynamicResource Text3Brush}" BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1" Padding="7,2" FontSize="10.5" FontFamily="Segoe UI" Cursor="Hand" Style="{StaticResource RoundedButtonSmall}"/>
                                    <Button Content="&#x6E05;&#x7A7A;" Click="ClearEffects_Click"
                                            Background="{DynamicResource Surface2Brush}" Foreground="{DynamicResource Text3Brush}" BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1" Padding="7,2" FontSize="10.5" FontFamily="Segoe UI" Margin="6,0,0,0" Cursor="Hand" Style="{StaticResource RoundedButtonSmall}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent">
                            <StackPanel x:Name="EffectsList"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource PreviewBgBrush}" Margin="20">
                        <Grid>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Width="420" Height="263"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="True">
                                <Grid>
                                    <Image x:Name="EffectPreviewImageA" Stretch="UniformToFill" Opacity="1"/>
                                    <Image x:Name="EffectPreviewImageB" Stretch="UniformToFill" Opacity="0"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,16">
                        <DockPanel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="SelectedEffectName" Text="Fade" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="SelectedEffectDesc" Text="" FontSize="12" Foreground="{DynamicResource Text2Brush}"
                                           FontFamily="Segoe UI" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock x:Name="SelectedEffectCount" Text="0" FontSize="24" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas" HorizontalAlignment="Center"/>
                                <TextBlock Text="&#x5DF2;&#x9009;&#x6548;&#x679C;" FontSize="10.5" Foreground="{DynamicResource Text3Brush}"
                                           FontFamily="Segoe UI" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="SettingsPanel" Visibility="Collapsed" Margin="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Background="{DynamicResource Surface2Brush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                <TextBlock Text="&#x64AD;&#x653E;&#x65F6;&#x957F;" Padding="16,12,16,10" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Text3Brush}" FontFamily="Segoe UI"/>
                            </Border>
                            <DockPanel Margin="16,12" LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="&#x6BCF;&#x5F20;&#x5C55;&#x793A;&#x65F6;&#x957F;" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextBrush}" FontFamily="Segoe UI"/>
                                    <TextBlock Text="&#x56FE;&#x7247;&#x9759;&#x6B62;&#x5C55;&#x793A;&#x7684;&#x65F6;&#x95F4;" FontSize="11" Foreground="{DynamicResource Text3Brush}" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                    <Button x:Name="DisplayDurationMinusBtn" Width="26" Height="30" Click="DisplayDurationMinus_Click" Cursor="Hand"/>
                                    <TextBlock x:Name="DisplayDurationValue" Text="5.0" Width="48" Height="30" TextAlignment="Center" VerticalAlignment="Center" Background="{DynamicResource Surface2Brush}" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas" FontSize="13"/>
                                    <TextBlock Text="&#x79D2;" FontSize="11" Foreground="{DynamicResource Text3Brush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    <Button x:Name="DisplayDurationPlusBtn" Width="26" Height="30" Cursor="Hand" Margin="4,0,0,0" Click="DisplayDurationPlus_Click"/>
                                </StackPanel>
                            </DockPanel>
                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="16,0"/>
                            <DockPanel Margin="16,12" LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="&#x8FC7;&#x6E21;&#x52A8;&#x753B;&#x65F6;&#x957F;" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextBrush}" FontFamily="Segoe UI"/>
                                    <TextBlock Text="&#x5207;&#x6362;&#x52A8;&#x753B;&#x64AD;&#x653E;&#x65F6;&#x95F4;" FontSize="11" Foreground="{DynamicResource Text3Brush}" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                    <Button x:Name="TransitionDurationMinusBtn" Width="26" Height="30" Click="TransitionDurationMinus_Click" Cursor="Hand"/>
                                    <TextBlock x:Name="TransitionDurationValue" Text="1.2" Width="48" Height="30" TextAlignment="Center" VerticalAlignment="Center" Background="{DynamicResource Surface2Brush}" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas" FontSize="13"/>
                                    <TextBlock Text="&#x79D2;" FontSize="11" Foreground="{DynamicResource Text3Brush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    <Button x:Name="TransitionDurationPlusBtn" Width="26" Height="30" Cursor="Hand" Margin="4,0,0,0" Click="TransitionDurationPlus_Click"/>
                                </StackPanel>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Background="{DynamicResource Surface2Brush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                <TextBlock Text="&#x56FE;&#x7247;&#x538B;&#x7F29;" Padding="16,12,16,10" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Text3Brush}" FontFamily="Segoe UI"/>
                            </Border>
                            <StackPanel Margin="16,12">
                                <DockPanel>
                                    <StackPanel>
                                        <TextBlock Text="JPEG &#x538B;&#x7F29;&#x8D28;&#x91CF;" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextBrush}" FontFamily="Segoe UI"/>
                                        <TextBlock Text="&#x6570;&#x503C;&#x8D8A;&#x4F4E;&#x4F53;&#x79EF;&#x8D8A;&#x5C0F;" FontSize="11" Foreground="{DynamicResource Text3Brush}" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="QualityValue" Text="75%" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas" HorizontalAlignment="Right"/>
                                </DockPanel>
                                <Slider x:Name="QualitySlider" Minimum="40" Maximum="90" Value="75" SmallChange="5" LargeChange="10" Margin="0,10" IsSnapToTickEnabled="True" TickFrequency="5" ValueChanged="QualitySlider_ValueChanged"/>
                                <DockPanel>
