<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 🎨 语义颜色 — 浅色主题 -->
    <Color x:Key="BgColor">#F0F1F5</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="Surface2Color">#E8E9EF</Color>
    <Color x:Key="Surface3Color">#DDDEE6</Color>
    <Color x:Key="BorderColor">#CDD0DA</Color>
    <Color x:Key="Border2Color">#B0B4C2</Color>
    <Color x:Key="AccentColor">#5570E8</Color>
    <Color x:Key="AccentTransparentColor">#DA5570E8</Color>
    <Color x:Key="TextColor">#1A1D2A</Color>
    <Color x:Key="Text2Color">#555A70</Color>
    <Color x:Key="Text3Color">#8A90A6</Color>
    <Color x:Key="SuccessColor">#2AAF6A</Color>
    <Color x:Key="DangerColor">#DC4545</Color>
    <Color x:Key="DangerBgColor">#40DC4545</Color>
    <Color x:Key="PreviewBgColor">#E4E5EB</Color>
    <Color x:Key="CardBgColor">#F5F6FA</Color>
    <Color x:Key="CardBorderColor">#D8DAE2</Color>
    <Color x:Key="CardInfoSubColor">#8A8FA6</Color>
    <Color x:Key="CardInfoMainColor">#1A1D2A</Color>
    <Color x:Key="BadgeTextColor">#6B7090</Color>
    <Color x:Key="WhiteColor">#FFFFFF</Color>

    <!-- 🖌 画刷资源 -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="Surface3Brush" Color="{StaticResource Surface3Color}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="Border2Brush" Color="{StaticResource Border2Color}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentTransparentBrush" Color="{StaticResource AccentTransparentColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="Text2Brush" Color="{StaticResource Text2Color}"/>
    <SolidColorBrush x:Key="Text3Brush" Color="{StaticResource Text3Color}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerBgBrush" Color="{StaticResource DangerBgColor}"/>
    <SolidColorBrush x:Key="PreviewBgBrush" Color="{StaticResource PreviewBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>
    <SolidColorBrush x:Key="CardInfoSubBrush" Color="{StaticResource CardInfoSubColor}"/>
    <SolidColorBrush x:Key="CardInfoMainBrush" Color="{StaticResource CardInfoMainColor}"/>
    <SolidColorBrush x:Key="BadgeTextBrush" Color="{StaticResource BadgeTextColor}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource WhiteColor}"/>

</ResourceDictionary>
