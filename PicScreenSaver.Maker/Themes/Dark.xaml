<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 🎨 语义颜色 — 深色主题 -->
    <Color x:Key="BgColor">#0F1117</Color>
    <Color x:Key="SurfaceColor">#171A22</Color>
    <Color x:Key="Surface2Color">#1E2129</Color>
    <Color x:Key="Surface3Color">#252932</Color>
    <Color x:Key="BorderColor">#2C3040</Color>
    <Color x:Key="Border2Color">#363B4E</Color>
    <Color x:Key="AccentColor">#6B8CFF</Color>
    <Color x:Key="AccentTransparentColor">#DA6B8CFF</Color>
    <Color x:Key="TextColor">#E4E6F0</Color>
    <Color x:Key="Text2Color">#8A90A8</Color>
    <Color x:Key="Text3Color">#565C74</Color>
    <Color x:Key="SuccessColor">#3ECF8E</Color>
    <Color x:Key="DangerColor">#F06C6C</Color>
    <Color x:Key="DangerBgColor">#40F06C6C</Color>
    <Color x:Key="PreviewBgColor">#0A0B10</Color>
    <Color x:Key="CardBgColor">#1F1F23</Color>
    <Color x:Key="CardBorderColor">#38383F</Color>
    <Color x:Key="CardInfoSubColor">#606070</Color>
    <Color x:Key="CardInfoMainColor">#E8E8F0</Color>
    <Color x:Key="BadgeTextColor">#9898A8</Color>
    <Color x:Key="WhiteColor">#FFFFFF</Color>

    <!-- 🖌 画刷资源 -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="Surface3Brush" Color="{StaticResource Surface3Color}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="Border2Brush" Color="{StaticResource Border2Color}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentTransparentBrush" Color="{StaticResource AccentTransparentColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="Text2Brush" Color="{StaticResource Text2Color}"/>
    <SolidColorBrush x:Key="Text3Brush" Color="{StaticResource Text3Color}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerBgBrush" Color="{StaticResource DangerBgColor}"/>
    <SolidColorBrush x:Key="PreviewBgBrush" Color="{StaticResource PreviewBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>
    <SolidColorBrush x:Key="CardInfoSubBrush" Color="{StaticResource CardInfoSubColor}"/>
    <SolidColorBrush x:Key="CardInfoMainBrush" Color="{StaticResource CardInfoMainColor}"/>
    <SolidColorBrush x:Key="BadgeTextBrush" Color="{StaticResource BadgeTextColor}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource WhiteColor}"/>

</ResourceDictionary>
